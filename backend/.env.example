# ─────────────────────────────────────────────────────────────────────────────
# PetGraph — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM keys (at least one required for document upload; seed graph works without)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM settings
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── Cognee (mirrors OPENAI_API_KEY for Cognee's internal LLM calls)
LLM_API_KEY=sk-proj-...
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false

# ── Storage paths — docker-compose sets DATA_DIR=/data automatically
# Leave unset for local dev (falls back to backend/ directory)
# DATA_DIR=/data

# ── Optional: Postgres vector+relational backend (--profile postgres)
# DB_PROVIDER=postgres
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=cognee_db
# DB_USERNAME=cognee
# DB_PASSWORD=cognee

# ── Optional: Neo4j graph backend (--profile neo4j)
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_URL=bolt://neo4j:7687
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=pleaseletmein
# NEO4J_AUTH=neo4j/pleaseletmein
