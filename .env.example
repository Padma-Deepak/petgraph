# Copy to .env (same folder) before `docker compose up`.
# The key is OPTIONAL: seed data, graph, reminders, insights, and conflicts
# work without it. Only the Ask chat, document upload, and Visit prep need it.
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# API_PORT=8000
# UI_PORT=5173
